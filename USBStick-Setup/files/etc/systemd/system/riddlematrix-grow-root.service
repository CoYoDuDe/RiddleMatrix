[Unit]
Description=Grow RiddleMatrix root filesystem on first boot
DefaultDependencies=no
After=local-fs.target
Before=multi-user.target
ConditionPathExists=!/var/lib/riddlematrix-grow-root.done

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/riddlematrix-grow-root.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
