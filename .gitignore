# Ignore Arduino build directories
build/

# Ignore compiled binary files
*.bin
*.elf
*.map

# Additional Arduino IDE temporary files
*.hex
*.eep
*.o
*.d

# Allow configuration directories moved under USBStick-Setup/files
!USBStick-Setup/files/
!USBStick-Setup/files/**
!USBStick-Setup/hooks.d/
!USBStick-Setup/hooks.d/**

# Mac OS and other system files
.DS_Store

# PlatformIO
.pio/
.vscode/

# Local test environment
.venv/
.pytest_cache/
__pycache__/
tests/__pycache__/

# Local build artifacts
dist/
dist-public/

# Private local/server defaults. Do not commit customer credentials.
src/private_defaults.h
